{
  "name": "dashboard-generator",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "tsx scripts/validate-dashboard.ts",
    "generate:test": "tsx scripts/generate-test-dashboard.ts",
    "cf:build": "npx @opennextjs/cloudflare build",
    "cf:dev": "wrangler dev",
    "deploy": "npx @opennextjs/cloudflare build && wrangler deploy",
    "deploy:force": "npx @opennextjs/cloudflare build --dangerouslyUseUnsupportedNextVersion && wrangler deploy",
    "deploy:staging": "npx @opennextjs/cloudflare build --dangerouslyUseUnsupportedNextVersion && wrangler deploy --env staging",
    "promote": "npx @opennextjs/cloudflare build --dangerouslyUseUnsupportedNextVersion && wrangler deploy"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "next": "^14.2.0",
    "papaparse": "^5.4.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "@opennextjs/cloudflare": "^1.0.0",
    "vitest": "^4.0.18",
    "wrangler": "^3.0.0"
  }
}
